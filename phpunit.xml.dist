<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="tests/phpunit/bootstrap.php"
    colors="true"
    cacheResult="false"
    beStrictAboutOutputDuringTests="true"
>
    <testsuites>
        <testsuite name="Spectre Icons">
            <directory>tests/phpunit</directory>
        </testsuite>
    </testsuites>
</phpunit>
