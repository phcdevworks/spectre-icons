{
  "name": "spectre-icons",
  "version": "1.3.1",
  "private": true,
  "description": "WordPress plugin that adds bundled and uploaded SVG icon libraries to Elementor's icon picker, with per-library enable/disable controls.",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "check": "composer validate --no-check-lock && composer test && composer lint",
    "test": "npm run test:e2e",
    "test:php": "composer test",
    "test:e2e": "playwright test",
    "test:e2e:elementor": "playwright test tests/e2e/elementor",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "wp-env:start": "npx wp-env start",
    "wp-env:stop": "npx wp-env stop",
    "wp-env:install-elementor": "npx wp-env run cli wp plugin install elementor --activate",
    "test:e2e:setup": "npm run wp-env:start && npm run wp-env:install-elementor",
    "release:propose": "node ./node_modules/tsx/dist/cli.mjs scripts/propose-version.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phcdevworks/spectre-icons.git"
  },
  "keywords": [
    "wordpress",
    "elementor",
    "icons",
    "svg",
    "lucide",
    "font-awesome",
    "icon-picker",
    "plugin"
  ],
  "author": "PHCDevworks",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-icons/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-icons#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@wordpress/env": "^11.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
