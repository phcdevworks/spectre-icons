{
  "name": "spectre-icons",
  "version": "1.2.0",
  "description": "Spectre Icons brings modern SVG icon libraries like Lucide and Font Awesome into WordPress builders.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "npm run test:e2e",
    "test:php": "composer test",
    "test:e2e": "playwright test",
    "test:e2e:elementor": "playwright test tests/e2e/elementor",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "wp-env:start": "npx wp-env start",
    "wp-env:stop": "npx wp-env stop",
    "wp-env:install-elementor": "npx wp-env run cli wp plugin install elementor --activate",
    "test:e2e:setup": "npm run wp-env:start && npm run wp-env:install-elementor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phcdevworks/spectre-icons.git"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-2.0-or-later",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/phcdevworks/spectre-icons/issues"
  },
  "homepage": "https://github.com/phcdevworks/spectre-icons#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@wordpress/env": "^11.4.0"
  }
}
